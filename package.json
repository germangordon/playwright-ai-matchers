{
  "name": "playwright-ai-matchers",
  "version": "2.0.0-beta.1",
  "description": "Provider-agnostic AI matchers for Playwright's expect() — ships with a Claude Opus 4.7 adapter using prompt caching, adaptive thinking, and forced tool use",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "playwright",
    "testing",
    "ai",
    "matchers",
    "expect",
    "anthropic",
    "claude",
    "llm"
  ],
  "license": "MIT",
  "author": "German Gordon",
  "peerDependencies": {
    "@google/generative-ai": ">=0.21.0",
    "@playwright/test": ">=1.40.0",
    "openai": ">=4.60.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": ">=0.85.0"
  },
  "devDependencies": {
    "@google/generative-ai": "^0.21.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "openai": "^4.77.0",
    "playwright-ai-matchers": "file:.",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
